# =============================================================================
# GitHub Actions — Repository Variables & Secrets
# oficina-tech-ms-workshop (MS3)
#
# Configure em: Settings → Secrets and Variables → Actions
# Docs: .github/README.md
# =============================================================================

# =============================================================================
# VARIABLES (Settings → Variables)
# Valores não-sensíveis, visíveis nos logs do Actions.
# =============================================================================

# --- Infraestrutura (obrigatórias) ---
APP_NAME=ms-workshop
K8S_NAMESPACE=app-oficina-tech
AWS_REGION=us-east-1
INFRA_TFSTATE_S3_PATH=s3://<bucket>/infra/terraform.tfstate
DB_TFSTATE_S3_PATH=s3://<bucket>/db/terraform.tfstate

# --- SQS/SNS — Saga Participant (obrigatórias) ---
# Consome (MS2 → MS3)
SQS_INVENTORY_OP_REQUESTED_URL=https://sqs.us-east-1.amazonaws.com/<account>/order-inventory-op-requested
# Publica resultado (MS3 → MS2)
SQS_INVENTORY_OP_SUCCEEDED_URL=https://sqs.us-east-1.amazonaws.com/<account>/order-inventory-op-succeeded
SQS_INVENTORY_OP_FAILED_URL=https://sqs.us-east-1.amazonaws.com/<account>/order-inventory-op-failed
# SNS — side effect de alerta (não bloqueia saga)
SNS_INVENTORY_LOW_ALERT_ARN=arn:aws:sns:us-east-1:<account>:inventory-low-alert

# --- Serviço (opcionais — defaults no workflow) ---
SERVER_PORT=8083
HEALTH_ENDPOINT=/health
GO_VERSION=1.25
GO_MAIN_PATH=cmd/api/main.go

# --- Release (opcionais — defaults no workflow) ---
SOURCE_BRANCH=develop
BASE_BRANCH=main

# =============================================================================
# SECRETS (Settings → Secrets)
# Valores sensíveis, mascarados nos logs do Actions.
# =============================================================================

# --- AWS ---
AWS_ACCESS_KEY_ID=<access-key>
AWS_SECRET_ACCESS_KEY=<secret-key>
AWS_SESSION_TOKEN=<session-token>        # opcional (sessão temporária)

# --- Banco de dados ---
DB_PASSWORD=<senha-do-db_ms3>

# --- Autenticação (compartilhado com todos os MSs — mesmo valor) ---
JWT_SECRET_KEY=<secret-jwt-compartilhado>

# --- Container Registry ---
GHCR_PAT=<github-personal-access-token-com-escopo-packages>

# --- Monitoramento ---
DD_API_KEY=<datadog-api-key>
DD_APP_KEY=<datadog-app-key>
DD_SITE=datadoghq.com                   # opcional

# --- Qualidade ---
SONAR_TOKEN=<sonarqube-token>
SONAR_HOST_URL=https://<sonarqube-host>
