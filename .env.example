# =============================================================================
# MS3 — Workshop Service (Saga Participant)
# Copie para .env e preencha os valores antes de rodar localmente
# =============================================================================

# ─── Servidor ─────────────────────────────────────────────────────────────────
SERVER_PORT=8083

# ─── Banco de Dados ───────────────────────────────────────────────────────────
DB_HOST=localhost          # postgres-ms3 quando rodando via docker compose raiz
DB_PORT=5435               # 5432 quando rodando via docker-compose.yml individual
DB_USER=oficina
DB_PASSWORD=oficina
DB_NAME=db_ms3
DB_SSLMODE=disable

# ─── Autenticação JWT ─────────────────────────────────────────────────────────
# Mesmo segredo compartilhado com MS1 e MS2 (validação local)
JWT_SECRET_KEY=local-dev-secret

# ─── AWS — LocalStack (desenvolvimento local) ─────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566   # http://localstack:4566 dentro do Docker

# ─── AWS Academy (produção) ───────────────────────────────────────────────────
# Substitua pelas credenciais da sessão AWS Academy (expiram a cada sessão)
# AWS_ACCESS_KEY_ID=<copiado do AWS Details>
# AWS_SECRET_ACCESS_KEY=<copiado do AWS Details>
# AWS_SESSION_TOKEN=<copiado do AWS Details>
# AWS_REGION=us-east-1
# (remova AWS_ENDPOINT_URL para apontar para a AWS real)

# ─── SQS Queues ───────────────────────────────────────────────────────────────
# Convenção do código: <QUEUE_NAME_UPPER>_QUEUE_URL
# (resolvido automaticamente via GetQueueUrl quando AWS_ENDPOINT_URL está definido;
#  SQS_AUTO_CREATE_QUEUES=true como fallback adicional)
ORDER_INVENTORY_OP_REQUESTED_QUEUE_URL=http://localhost:4566/000000000000/order-inventory-op-requested
ORDER_INVENTORY_OP_SUCCEEDED_QUEUE_URL=http://localhost:4566/000000000000/order-inventory-op-succeeded
ORDER_INVENTORY_OP_FAILED_QUEUE_URL=http://localhost:4566/000000000000/order-inventory-op-failed

# ─── SNS ──────────────────────────────────────────────────────────────────────
SNS_INVENTORY_LOW_ALERT_ARN=arn:aws:sns:us-east-1:000000000000:inventory-low-alert
